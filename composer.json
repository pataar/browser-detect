{
  "name": "pataar/browser-detect",
  "description": "Browser & Mobile detection package for Laravel.",
  "keywords": [
    "laravel",
    "user-agent",
    "browser",
    "mobile",
    "detect",
    "tablet",
    "user agent",
    "analyse",
    "hisorange"
  ],
  "homepage": "https://github.com/pataar/browser-detect",
  "license": "MIT",
  "authors": [
    {
      "name": "Varga Zsolt",
      "email": "hello@hisorange.me"
    },
    {
      "name": "Pieter Willekens",
      "email": "me@pataar.nl"
    }
  ],
  "require": {
    "php": "^8.3",
    "jaybizzle/crawler-detect": "^1.4",
    "matomo/device-detector": "^6.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0 || ^12.0 || ^13.0",
    "orchestra/testbench": "^10.0 || ^11.0",
    "phpstan/phpstan": "^2.2",
    "laravel/pint": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "hisorange\\BrowserDetect\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "hisorange\\BrowserDetect\\Test\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "extra": {
    "laravel": {
      "providers": [
        "hisorange\\BrowserDetect\\ServiceProvider"
      ],
      "aliases": {
        "Browser": "hisorange\\BrowserDetect\\Facade"
      }
    }
  },
  "scripts": {
    "analyse": "phpstan analyse",
    "lint": "pint",
    "test": "phpunit",
    "test-with-coverage": "phpunit --coverage-clover ./build/logs/clover.xml"
  }
}
